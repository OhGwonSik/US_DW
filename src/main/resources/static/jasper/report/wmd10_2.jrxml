						<font fontName="JasperNanumFont" size="8"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{boxcnt} == null ? " " : $F{boxcnt}]]></textFieldExpression>
				</textField>
			</frame>
		</band>
	</detail>
</jasperReport>
