<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.logistics.chunglim.mapper.TbTestMapper">

	<select id="selectTbTests" parameterType="com.logistics.chunglim.vo.TbTestVO">
		SELECT * FROM H1.tb_test
	</select>
	<insert id="insertTbTest">
		INSERT INTO TB_TEST(TT_NAME)
		VALUES(#{ttName})
	</insert>
</mapper>
