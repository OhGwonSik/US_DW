    omp4 : 발주 List 조회 
    <select id="selectOmp4List" resultType="com.logistics.om.domain.PurchaseDTO">
     	select OC.COMPKEY
		     , OC.COPODKY
		     , OC.COPODIT
		     , OC.PURSTAT
		     , date_format(OC.PURDATE, '%Y-%m-%d') as PURDATE
		     , date_format(OC.PURTIME, '%H-%i-%s') as PURTIME
		     , OC.OWNERKY
		     , OC.SKUMKEY
		     , OC.SKUDESC
		     , OC.POITQTY
		     , format(OC.POITQTY / MS.ROINQTY,1) as GPAKCNT
		     , OC.SKUSKEY
		     , OC.PODMEMO
		     , OC.PODELYN
		     , OC.RCVWHKY
		     , date_format(OC.REQDATE, '%Y-%m-%d') as REQDATE
		     , date_format(OC.REQTIME, '%H-%i-%s') as REQTIME
		     , OC.REQMEMO
		     , OC.VENDKEY
		     , MP.PTNAMLC as VENDNAM
		     , OC.CUSTKEY 
		     , MC1.CUNAMLC as CUSTNAM
		     , OC.RETAKEY
		     , MC2.CUNAMLC as RETANAM
		     , OC.COOUTKY
		     , OC.COOUTIT
		     , date_format(OC.CREDATE, '%Y-%m-%d') as CREDATE, date_format(OC.CRETIME, '%H-%i-%s') as CRETIME, fn_sy_usernam(OC.COMPKEY,OC.CREUSER) as CREUSER
		     , date_format(OC.LMODATE, '%Y-%m-%d') as LMODATE, date_format(OC.LMOTIME, '%H-%i-%s') as LMOTIME, fn_sy_usernam(OC.COMPKEY,OC.LMOUSER) as LMOUSER
		  from OCOPUR OC
		 inner join MPTNMA MP
		    on MP.COMPKEY = OC.COMPKEY
		   and MP.PTNRKEY = OC.VENDKEY
		   and MP.PTNRTYP = 'VENDER'
		 inner join MSKUWC MS
		    on MS.COMPKEY = OC.COMPKEY
		   and MS.WAREKEY = OC.RCVWHKY
		   and MS.OWNERKY = OC.OWNERKY
		   and MS.SKUMKEY = OC.SKUMKEY
		 inner join MCUSMA MC1
		    on MC1.COMPKEY = OC.COMPKEY
		   and MC1.CUSTKEY = OC.CUSTKEY
		   and MC1.OWNERKY = OC.OWNERKY
		   and MC1.CUSTTYP = 'WHOLESALE'
		  left join MCUSMA MC2
		    on MC2.COMPKEY = OC.COMPKEY
		   and MC2.CUSTKEY = OC.RETAKEY
		   and MC2.OWNERKY = OC.OWNERKY
		   and MC2.CUSTTYP = 'RETAIL'
		 where 1=1
		   and OC.COMPKEY = #{userData.compkey}
		   and OC.OWNERKY = #{userData.ownerky}
		<if test="custkey != null and  custkey != ''">
		   and OC.CUSTKEY = #{custkey}
		</if>
		<if test="retanam != null and  retanam != ''">
		   AND upper(MM2.CUNAMLC) LIKE CONCAT('%', upper(#{retanam}), '%')
		</if>
		<if test="vendnam != null and  vendnam != ''">
		   AND upper(MP.PTNAMLC) LIKE CONCAT('%', upper(#{vendnam}), '%') 
		</if>
		<if test="copodky != null and  copodky != ''">
		   and OC.COPODKY = #{copodky} 
		</if>
		<choose>
        	<when test='purdatefrom != null and purdatefrom != "" and purdateto == ""'>
 <![CDATA[ and OC.PURDATE >= replace(#{purdatefrom}, '-', '') ]]>
			</when>
			<when test='purdateto != null and purdateto != "" and purdatefrom == ""'>
 <![CDATA[ and OC.PURDATE <= replace(#{purdateto}, '-', '') ]]>
			</when>
			<when test='purdatefrom != null and purdatefrom != "" and purdateto != null and purdateto != ""'>
		   and OC.PURDATE between replace(#{purdatefrom}, '-', '') and replace(#{purdateto}, '-', '')
			</when>	
		</choose>
		<if test="skudesc != null and  skudesc != ''">
		   and upper(OC.SKUDESC) LIKE CONCAT('%', upper(#{skudesc}), '%')
		</if>
		<if test='purstats != null and purstats.size > 0'>
		   and OC.PURSTAT in
		   	<foreach collection="purstats" item="item" index="index" open="(" close=")" separator=",">
		   	 #{item}
		   	</foreach>
		</if>
		 order by OC.COMPKEY, OC.COPODKY, OC.COPODIT
		 
    </select>
    
