<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.logistics.om.mapper.PurchaseMapper">
 	
	<!-- purchase common : partner select box  -->
	<select id="selectPartnerSelectBox" resultType="com.logistics.md.domain.MptnmaVO">
		/*selectPartnerSelectBox*/
		select PTNRKEY
			 , PTNAMLC
		  from MPTNMA 
		  <where>
		 		COMPKEY = #{userData.compkey}
		 	<if test='ptnrtyp != null and ptnrtyp != ""'>
		 		and PTNRTYP = #{ptnrtyp}
		 	</if>
		 	<if test='partners != null and partners.size > 0'>
	  			and PTNRTYP IN 
	  			<foreach collection="partners" item="item" index="index" open="(" close=")" separator=",">
					UPPER(#{item})
				</foreach>
	  		</if>
	  			and PTUSEYN = 'Y'
		  </where>
		  order by PTNRORD asc
	</select>
	
	<!-- purchase common : destination select box  -->
	<select id="selectDestkeySelectBox" resultType="com.logistics.pt.MdesmaVO">
		/*selectDestkeySelectBox*/
		select DESTKEY
			 , DENAMLC
		  from MDESMA
		  <where>
		    	COMPKEY = #{userData.compkey}
		    <if test='ptnrkey != null and ptnrkey != ""'>
				and PTNRKEY = UPPER(#{ptnrkey})
		    </if>
	    		and DEUSEYN = 'Y'
		  </where>
	</select>
	
    <!-- omp01, omp02 : 발주 키 채번 Copodky --> 
    <select id="selectCopodky" resultType="String">
    	/* selectCopodky */
     	select fn_om_copodky() as copodky from dual
    </select>
    
    <!-- ASN 키 채번 -->
    <select id="selectEoasnky" resultType="String">
     	/* selectEoasnky */
     	select fn_wm_eoasnky() as eoasnky from dual
    </select>
    
    <!-- omp01 및 omp02 OCOPUR INSERT  -->
    <insert id="insertOcopur" parameterType="com.logistics.om.domain.PurchaseDTO">
    	/*insertOcopur*/
    	insert 
     	  into OCOPUR ( 
     	  				COMPKEY, COPODKY, COPODIT, DOCCATE
     	  			  , DOCTYPE, PURSTAT, PURDATE, PURTIME
     	  			  , CUSTKEY, VENDKEY, OWNERKY, SKUMKEY
     	  			  , SKUDESC, POITQTY, PUOMKEY, SKUSKEY
     	  			  , PODMEMO, RCVWHKY, REQDATE, REQTIME
					  , REQMEMO, COOUTKY, COOUTIT, DCTCTYP
					  , DESTKEY, RCHSQTY, CREDATE, CRETIME
					  , CREUSER, LMODATE, LMOTIME, LMOUSER 
					  )
		VALUES 
		(
			#{userData.compkey}, #{copodky}, #{copodit}, #{doccate}
		  , #{doctype}, #{purstat}, date_format(NOW() , '%Y%m%d'), date_format(NOW() , '%H%i%s')
		  , #{custkey}, IFNULL(#{vendkey}, ''), #{ownerky}, #{skumkey}
		  , #{skudesc}, #{poitqty}, #{puomkey}, IFNULL(#{skuskey}, '')
		  , IFNULL(#{podmemo}, ''), #{rcvwhky}, replace(#{reqdate},'-',''), replace(#{reqtime},':','') 
		  , IFNULL(#{reqmemo}, ''), '', 0, ''
		  , #{destkey}, #{poitqty}, date_format(NOW() , '%Y%m%d'), date_format(NOW() , '%H%i%s')
		  , #{userData.useract}, date_format(NOW() , '%Y%m%d') , date_format(NOW() , '%H%i%s'), #{userData.useract} 
		)
    </insert>
    
    <!-- omp01 및 omp02 WASNIF INSERT  -->    
    <insert id="insertWasnif" parameterType="com.logistics.om.domain.PurchaseDTO">
   	 	/*insertWasnif*/
    	insert
           into WASNIF (
                         COMPKEY, EOASNKY, EOASNIT, WAREKEY
                       , DOCCATE, DOCTYPE, ASNSTAT, ASNDATE
                       , ASNTIME, OWNERKY, SKUMKEY, SKUDESC
                       , SKUSKEY, POITQTY, PUOMKEY, ASNDQTY
                       , AUOMKEY, VENDKEY, CUSTKEY, DESTKEY
                       , EXPIDAT, TRUNTYP, COPODKY, COPODIT
                       , CARRKEY, TRUCKNO, TRUCTON, ASNMEMO
                       , CREDATE, CRETIME, CREUSER, LMODATE
                       , LMOTIME, LMOUSER 
                   	   )
       	 VALUES
	     (
	          #{userData.compkey}, #{eoasnky}, #{eoasnit}, #{warekey}
	        , #{doccate}, #{doctype}, #{asnstat}, replace(#{asndate}, '-', '')
	        , replace(#{asntime}, ':', '') , #{ownerky}, #{skumkey}, #{skudesc}
	        , IFNULL(#{skuskey}, ''), #{asndqty}, #{puomkey}, #{asndqty}
	        , #{auomkey}, IFNULL(#{vendkey}, ''), #{custkey}, #{destkey}
	        , replace(#{expidat}, '-', ''), IFNULL(#{truntyp}, ''), #{copodky}, #{copodit}
	        , IFNULL(#{carrkey}, ''), IFNULL(#{truckno}, ''), IFNULL(#{tructon}, ''), IFNULL(#{asnmemo}, '')
	        , date_format(NOW() , '%Y%m%d'), date_format(NOW() , '%H%i%s'), #{userData.useract}, date_format(NOW() , '%Y%m%d') 
	        , date_format(NOW() , '%H%i%s'), #{userData.useract} 
	     );
    </insert>
 
    <!-- omp04 ASN List 조회 -->
	<select id="selectWasnifList" resultType="com.logistics.om.domain.PurchaseDTO">
		/*selectWasnifList*/
        select CONCAT(WA.COMPKEY, WA.EOASNKY, WA.EOASNIT) as ROWKEY 
             , WA.COMPKEY, WA.EOASNKY, WA.EOASNIT
             , WA.WAREKEY
             , MW.WHNAMLC 
             , MA.DOCCTNM AS DOCCATE
             , WA.DOCTYPE
             , MA.DOCTYNM 
             , WA.ASNSTAT
             , (
                 select MC.COMCDTX 
	               from V_MCODEM MC
	              where MC.COMPKEY = #{userData.compkey}
	                and MC.COMCDVL = WA.ASNSTAT 
	                and MC.COMCDKY = 'ASNSTAT'
	                and MC.COUSEYN = 'Y'
               ) AS COMCDTX
             , IFNULL(ST.STOTQTY , 0) as STOTQTY
             , date_format(str_to_date(WA.ASNDATE, '%Y%m%d'), '%Y-%m-%d') as ASNDATE
             , date_format(str_to_date(WA.ASNTIME, '%H%i%s'), '%H:%i:%s') as ASNTIME
             , MO.OWNAMLC AS OWNERKY
             , MS.SKUMKEY
             , MS.SKUDESC
             , MS.SKUSKEY
             , MS.PROPQTY
             , MS.SALFQTY
             , MS.MINIQTY
             , WA.SIRBCOD
             , WA.POITQTY
             , WA.PUOMKEY
             , WA.ASNDQTY
             , WA.AUOMKEY
             , WA.TRUNTYP
             , WA.RCHSQTY
             , WA.RCHPQTY
             , WA.RCHSUOM
             , IFNULL(MPA.PACKQTY, 0) as PACKQTY
             , IFNULL(CEILING(WA.ASNDQTY / MPA.PACKQTY), '0') AS ASITBOX
             , (
		         select MP.PTNAMLC
		           from MPTNMA MP
		          where MP.COMPKEY = WA.COMPKEY
		       	    and MP.PTNRKEY = WA.CUSTKEY
		       	    and MP.PTNRTYP = 'VENDER'
		       	    and MP.PTUSEYN = 'Y'
	           ) AS VENDKEY
             , (
		         select MP.PTNAMLC
		           from MPTNMA MP
		          where MP.COMPKEY = WA.COMPKEY
		      	    and MP.PTNRKEY = WA.CUSTKEY
		      	    and MP.PTNRTYP = 'CARRIER'
		       	    and MP.PTUSEYN = 'Y'
	           ) AS CARRKEY
             , WA.TRUCKNO
             , (
	           	 select MC.COMCDTX
	          	   from V_MCODEM MC
	              where MC.COMPKEY = WA.COMPKEY 
	                and MC.COMCDVL = WA.TRUCTON
	                and MC.COMCDKY = 'VHCTNCD'
	                and MC.COUSEYN = 'Y'
      	 	   ) AS TRUCTON
             , WA.ASNMEMO
             , WA.PRODDAT
             , WA.SHELIFE
             , WA.EXPIDAT
             , (
		         select MP.PTNAMLC
		           from MPTNMA MP
		          where MP.COMPKEY = WA.COMPKEY
		       	    and MP.PTNRKEY = WA.CUSTKEY
		      	    and MP.PTNRTYP IN ('CUSTOMER', 'WH') 
		       	    and MP.PTUSEYN = 'Y'
	           ) AS CUSTKEY
             , (
		         select MD.DENAMLC 
		           from MDESMA MD
		          where MD.COMPKEY = WA.COMPKEY
		       	    and MD.DESTKEY = WA.DESTKEY
		       	    and MD.PTNRKEY = WA.CUSTKEY
		       	    and MD.DEUSEYN = 'Y'
               ) AS DESTKEY
             , WA.LOTAT01
             , WA.LOTAT02
             , WA.LOTAT03
             , WA.LOTAT04
             , WA.LOTAT05
             , WA.LOTAT06
             , WA.LOTAT07
             , WA.LOTAT08
             , WA.LOTAT09
             , WA.LOTAT10
             , WA.LOTAT11
             , WA.LOTAT12
             , WA.LOTAT13
             , WA.LOTAT14
             , WA.LOTAT15
             , WA.LOTAT16
             , WA.LOTAT17
             , WA.LOTAT18
             , WA.LOTAT19
             , WA.LOTAT20
             , (	        
              	 select MC.COMCDTX
	               from V_MCODEM MC
	              where MC.COMPKEY = WA.COMPKEY
	                and MC.COMCDVL = WA.STKSTAT
	                and MC.COMCDKY = 'STKSTAT'
	                and MC.COUSEYN = 'Y'
      		   ) AS STKSTAT	  
             , ( 
		         select MR.RSNCDNM
		           from MRSCMA MR
		          where MR.COMPKEY = WA.COMPKEY
		            and MR.WAREKEY = WA.WAREKEY
		            and MR.DOCCATE = WA.DOCCATE
		            and MR.DOCTYPE = WA.DOCTYPE
		            and MR.RSNCODE = WA.RSNCODE
		            and MR.RSUSEYN = 'Y'
               ) AS RSNCODE
             , WA.RCVSRMK
             , WA.COPODKY
             , WA.COPODIT
             , WA.REFSODC
             , WA.REFSOIT
             , WA.REFDNDC
             , WA.REFDNIT
             , WA.REFSDDC
             , WA.REFSDIT
             , date_format(str_to_date(WA.CREDATE, '%Y%m%d'), '%Y-%m-%d') as CREDATE
             , date_format(str_to_date(WA.CRETIME, '%H%i%s'), '%H:%i:%s') as CRETIME
             , ( SELECT USERNAM 
	       		   FROM V_SUSRMA  
	      		  WHERE COMPKEY = #{userData.compkey}
	      		  AND USERACT = WA.CREUSER
	      	   ) as CREUSER
             , date_format(str_to_date(WA.LMODATE, '%Y%m%d'), '%Y-%m-%d') as LMODATE
             , date_format(str_to_date(WA.LMOTIME, '%H%i%s'), '%H:%i:%s') as LMOTIME
             , ( SELECT USERNAM 
	       		   FROM V_SUSRMA  
	      		  WHERE COMPKEY = #{userData.compkey}
	      		  AND USERACT = WA.LMOUSER
	      	   ) as LMOUSER
             , WA.INDIBZL
             , WA.INDIARC
             , WA.UPDTCHK
          from WASNIF WA
          INNER JOIN MSKUWC MS
             on WA.COMPKEY = MS.COMPKEY
            and WA.WAREKEY = MS.WAREKEY
            and WA.OWNERKY = MS.OWNERKY
            and WA.SKUMKEY = MS.SKUMKEY
          INNER JOIN MDOCMA MA
      	     on MA.COMPKEY = WA.COMPKEY
      	    and MA.WAREKEY = WA.WAREKEY
      	    and MA.DOCTYPE = WA.DOCTYPE
      	    and MA.DOCCATE = WA.DOCCATE      
      	    and MA.DOUSEYN = 'Y'
      	  INNER JOIN MWARMA MW
      	     on MW.COMPKEY = WA.COMPKEY
      	    and MW.WAREKEY = WA.WAREKEY
      	    and MW.WHUSEYN = 'Y'
      	  INNER JOIN MOWRMA MO
      	     on MO.COMPKEY = WA.COMPKEY
      	    and MO.OWNERKY = WA.OWNERKY
      	    and MO.OWUSEYN = 'Y'
      	   LEFT JOIN MPAKMA MPA
             on MPA.COMPKEY = MS.COMPKEY
            and MPA.PACKKEY = MS.PACKKEY
            and MPA.WAREKEY = MS.WAREKEY
            and MPA.TRUNTYP = MS.TRUNTYP
            and MPA.PKUSEYN = 'Y'
           LEFT JOIN 
           (
	          select COMPKEY, OWNERKY, WAREKEY, SKUMKEY
	               , sum(STOTQTY)- sum(SBLOQTY) as STOTQTY
	            from WSTKKY
	           where COMPKEY = #{userData.compkey}
	             and WAREKEY = #{warekey}
	             and AREAKEY = 'STG'
	             and SALLQTY = 0
	             and SINBQTY = 0
	             and SOUBQTY = 0
	           group by COMPKEY, WAREKEY, OWNERKY, SKUMKEY
           ) ST 
             on ST.COMPKEY = MS.COMPKEY
            and ST.WAREKEY = MS.WAREKEY
            and ST.OWNERKY = MS.OWNERKY
            and ST.SKUMKEY = MS.SKUMKEY
		<where>
			WA.COMPKEY = #{userData.compkey}
			<choose>
				<when test='userData.ownerky != null and userData.ownerky != ""'>
		 			AND WA.OWNERKY = #{userData.ownerky}
		 			<if test='(doctypes == null or doctypes.size == 0) and (doctype == null or doctype == "")'>
		 				AND WA.DOCTYPE IN ('410', '420', '430')
		 			</if>
		 			<if test='(asnstat == null or asnstat == "") and (asnstats == null or asnstats.size == 0)'>
		 				AND WA.ASNSTAT NOT IN ('CANCEL')
		 			</if>
				</when>
				<when test='ownerky != null and ownerky != ""'>
					AND WA.OWNERKY = #{ownerky}
				</when>
			</choose>
		 	<if test='doccate != null and doccate != ""'>
		 		AND WA.DOCCATE = #{doccate}
		 	</if>
		 	<if test='doctype != null and doctype != ""'>
		 		AND WA.DOCTYPE = #{doctype}
		 	</if>
		 	<if test='warekey != null and warekey != ""'>
				AND WA.WAREKEY = #{warekey}
			</if>
			<if test='eoasnky != null and eoasnky != ""'>
				AND WA.EOASNKY LIKE CONCAT('%', #{eoasnky}, '%')
			</if>
			<if test='copodky != null and copodky != ""'>
				AND WA.COPODKY LIKE CONCAT('%', #{copodky}, '%')
			</if>
			<if test='skumkey != null and skumkey != ""'>
				AND WA.SKUMKEY LIKE CONCAT('%', UPPER(#{skumkey}), '%')
			</if>	
			<if test='skudesc != null and skudesc != ""'>
				AND WA.SKUDESC LIKE CONCAT('%', UPPER(#{skudesc}), '%')
			</if>	
			<if test='custkey != null and custkey != ""'>
				AND WA.CUSTKEY LIKE CONCAT('%', #{custkey}, '%')
			</if>	
			<if test='destkey != null and destkey != ""'>
				AND WA.DESTKEY LIKE CONCAT('%', #{destkey}, '%')
			</if>		
			<if test='asnstat != null and asnstat != ""'>
				AND WA.ASNSTAT IN (#{asnstat})
			</if>
			<if test='asnstats != null and asnstats.size > 0'>
				AND WA.ASNSTAT IN
		        <foreach collection="asnstats" item="item" index="index" open="(" close=")" separator=",">
					#{item}
				</foreach>
			</if>
			<if test='doctypes != null and doctypes.size > 0'>
				AND WA.DOCTYPE IN
		        <foreach collection="doctypes" item="item" index="index" open="(" close=")" separator=",">
					#{item}
				</foreach>
			</if>
			<choose>
		       	<when test='asndateFrom != null and asndateFrom != "" and asndateTo == ""'>
					<![CDATA[ and WA.ASNDATE >= replace(#{asndateFrom},'-','') ]]>
				</when>
				<when test='asndateTo != null and asndateTo != "" and asndateFrom == ""'>
					<![CDATA[ and WA.ASNDATE <= replace(#{asndateTo},'-','') ]]>
				</when>
				<when test='asndateFrom != null and asndateFrom != "" and asndateTo != null and asndateTo != ""'>
			   and WA.ASNDATE between replace(#{asndateFrom},'-','') and replace(#{asndateTo},'-','')
				</when>	
			</choose> 					
		</where>
		order by WA.EOASNKY desc , WA.EOASNIT asc
	</select>
	
	<!-- omp06 ASN 취소등록 Header List 조회 -->
	<select id="selectOmp06HeaderList" resultType="com.logistics.om.domain.PurchaseDTO">
		/* selectOmp06HeaderList */
		select CONCAT(WA.COMPKEY, WA.EOASNKY, WA.EOASNIT) as ROWKEY
			 , WA.COMPKEY
			 , WA.EOASNKY
			 , COUNT(1) as ITEMCNT
			 , IFNULL(SUM(ST.STOTQTY), 0) as STOTQTY
			 , IFNULL(SUM(WA.RCHSQTY), 0) as RCHSQTY
             , MW.WHNAMLC 
			 , WA.WAREKEY 
			 , WA.DOCCATE
			 , WA.DOCTYPE
             , MA.DOCCTNM
             , MA.DOCTYNM
			 , WA.COPODKY
			 , MO.OWNAMLC AS OWNERKY
             , (
		         select MP.PTNAMLC
		           from MPTNMA MP
		          where MP.COMPKEY = WA.COMPKEY
		       	    and MP.PTNRKEY = WA.CUSTKEY
		      	    and MP.PTNRTYP IN ('CUSTOMER', 'WH') 
		      	    and MP.PTUSEYN = 'Y'
	           ) AS CUSTKEY
             , (
		         select MD.DENAMLC 
		           from MDESMA MD
		          where MD.COMPKEY = WA.COMPKEY
		       	    and MD.DESTKEY = WA.DESTKEY
		       	    and MD.PTNRKEY = WA.CUSTKEY
		       	    and MD.DEUSEYN = 'Y'
               ) AS DESTKEY
			 , (
                 select MC.COMCDTX 
	               from V_MCODEM MC
	              where MC.COMPKEY = #{userData.compkey}
	                and MC.COMCDVL = WA.ASNSTAT 
	                and MC.COMCDKY = 'ASNSTAT'
	                and MC.COUSEYN = 'Y'
               ) AS ASNSTAT
			 , date_format(str_to_date(WA.ASNDATE, '%Y%m%d'), '%Y-%m-%d') as ASNDATE
			 , date_format(str_to_date(WA.ASNTIME, '%H%i%s'), '%H:%i:%s') as ASNTIME
			 , WA.AUOMKEY
			 , IFNULL(SUM(WA.ASNDQTY), 0) as ASNDQTY
             , IFNULL(SUM(CEILING(WA.ASNDQTY / MPA.PACKQTY)), '0') AS ASITBOX
			 , date_format(str_to_date(WA.CREDATE, '%Y%m%d'), '%Y-%m-%d') as CREDATE
			 , date_format(str_to_date(WA.CRETIME, '%H%i%s'), '%H:%i:%s') as CRETIME
			 , ( SELECT USERNAM 
	       		   FROM V_SUSRMA  
	      		  WHERE COMPKEY = #{userData.compkey}
	      		  AND USERACT = WA.CREUSER
	      	   ) as CREUSER
		   from WASNIF WA
          INNER JOIN MSKUWC MS
             on WA.COMPKEY = MS.COMPKEY
            and WA.WAREKEY = MS.WAREKEY
            and WA.OWNERKY = MS.OWNERKY
            and WA.SKUMKEY = MS.SKUMKEY
          INNER JOIN MDOCMA MA
      	     on MA.COMPKEY = WA.COMPKEY
      	    and MA.WAREKEY = WA.WAREKEY
      	    and MA.DOCTYPE = WA.DOCTYPE
      	    and MA.DOCCATE = WA.DOCCATE      
      	    and MA.DOUSEYN = 'Y'
      	  INNER JOIN MWARMA MW
      	     on MW.COMPKEY = WA.COMPKEY
      	    and MW.WAREKEY = WA.WAREKEY
      	    and MW.WHUSEYN = 'Y'
      	  INNER JOIN MOWRMA MO
      	     on MO.COMPKEY = WA.COMPKEY
      	    and MO.OWNERKY = WA.OWNERKY      
      	    and MO.OWUSEYN = 'Y'  
      	   LEFT JOIN MPAKMA MPA
             on MPA.COMPKEY = MS.COMPKEY
            and MPA.PACKKEY = MS.PACKKEY
            and MPA.WAREKEY = MS.WAREKEY
            and MPA.TRUNTYP = MS.TRUNTYP
            and MPA.PKUSEYN = 'Y'           
      	   LEFT JOIN 
      	   (
				select COMPKEY, OWNERKY, WAREKEY, SKUMKEY
		         	 , (sum(STOTQTY)- sum(SBLOQTY)) as STOTQTY
		          from WSTKKY
		         where COMPKEY = #{userData.compkey}
		           and WAREKEY = #{warekey}
		           and AREAKEY = 'STG'
		           and SALLQTY = 0
		           and SINBQTY = 0
		           and SOUBQTY = 0
		         group by COMPKEY, WAREKEY, OWNERKY, SKUMKEY
	       ) ST 
             on ST.COMPKEY = MS.COMPKEY
            and ST.WAREKEY = MS.WAREKEY
            and ST.OWNERKY = MS.OWNERKY
            and ST.SKUMKEY = MS.SKUMKEY
		<where>
			WA.COMPKEY = #{userData.compkey}
		and WA.ASNSTAT = #{asnstat}
			<choose>
				<when test='userData.ownerky != null and userData.ownerky != ""'>
		 			AND WA.OWNERKY = #{userData.ownerky}
		 			<if test='(doctypes == null or doctypes.size == 0) and (doctype == null or doctype == "")'>
		 				AND WA.DOCTYPE IN ('410', '420', '430')
		 			</if>
				</when>
				<when test='ownerky != null and ownerky != ""'>
					AND WA.OWNERKY = #{ownerky}
				</when>
			</choose>
			<if test='warekey != null and warekey != ""'>
				AND WA.WAREKEY = #{warekey}
			</if>
			<if test='eoasnky != null and eoasnky != ""'>
				AND WA.EOASNKY LIKE CONCAT('%', #{eoasnky}, '%')
			</if>
			<if test='copodky != null and copodky != ""'>
				AND WA.COPODKY LIKE CONCAT('%', #{copodky}, '%')
			</if>
			<if test='skumkey != null and skumkey != ""'>
				AND WA.SKUMKEY LIKE CONCAT('%', UPPER(#{skumkey}), '%')
			</if>	
			<if test='skudesc != null and skudesc != ""'>
				AND WA.SKUDESC LIKE CONCAT('%', UPPER(#{skudesc}), '%')
			</if>	
			<if test='custkey != null and custkey != ""'>
				AND WA.CUSTKEY LIKE CONCAT('%',#{custkey},'%')
			</if>	
			<if test='destkey != null and destkey != ""'>
				AND WA.DESTKEY LIKE CONCAT('%',#{destkey},'%')
			</if>
			<choose>
				<when test='asndateFrom != null and asndateFrom != "" and asndateTo == ""'>
					<![CDATA[ and WA.ASNDATE >= replace(#{asndateFrom},'-','') ]]>
				</when>
				<when test='asndateTo != null and asndateTo != "" and asndateFrom == ""'>
					<![CDATA[ and WA.ASNDATE <= replace(#{asndateTo},'-','') ]]>
				</when>
				<when test='asndateFrom != null and asndateFrom != "" and asndateTo != null and asndateTo != ""'>
					and WA.ASNDATE between replace(#{asndateFrom},'-','') and replace(#{asndateTo},'-','')
				</when>	
			</choose> 					
		</where>
		  group by WA.COPODKY, WA.EOASNKY 
		  order by WA.EOASNKY desc , WA.EOASNIT asc
	</select>
	
	<!-- omp06 ASN 취소등록 -->    
    <update id="updateAsnstatCancel" parameterType="com.logistics.om.domain.PurchaseDTO">
    	/* cancelWasnifList */
	   	update WASNIF
	   	   set ASNSTAT = 'CANCEL'
	   	   	 , RSNCODE = #{rsncode}
	   	   	 , RCVSRMK = #{rcvsrmk}
	   	   	 , UPDTCHK = #{updtchk} + 1
	   	     , LMODATE = DATE_FORMAT(NOW() ,'%Y%m%d')
		     , LMOTIME = DATE_FORMAT(NOW() ,'%H%i%s')
			 , LMOUSER = #{userData.useract}
		 where COMPKEY = #{userData.compkey}
		   and COPODKY = #{copodky}
		   and EOASNKY = #{eoasnky}
		   and UPDTCHK = ( select UPDTCHK from WASNIF 
		    			    where COMPKEY = #{userData.compkey} 
		    			      and COPODKY = #{copodky} 
		    			      and EOASNIT = #{eoasnit} 
		    			      and EOASNKY = #{eoasnky} 
