    omp3 : 임시 테이블 Sum List 조회 
    <select id="selectSoTempSum" resultType="com.logistics.om.domain.SalesOrderTempDTO">
     	select A.COMPKEY
			 , A.COPZZKY
			 , A.DCTCTYP
			 , A.DOCCATE	 
			 , A.DOCTYPE
			 , A.SKUSKEY
			 , A.SKUMKEY
			 , A.SKUMKEY as SKUMCOD
			 , A.SKUDESC
			 , A.VENDKEY
			 , A.VNDFDAY
			 , A.RCVDATE
			 , case when A.DCTCTYP = 'TC' then A.SOITQTY
			 	    when A.DCTCTYP = 'DC' and A.SALLBYN = 'Y' then A.SOITQTY
			 	    else 0 end as REFIQTY
			 , A.SPROPRC
			 , A.MINIQTY
			 , WS.ABALQTY
			 , TK.SQTY230
			 , S5.SQTY250
			 , WU.UNFLQTY
			 , S5.SQTY250 + WU.UNFLQTY as TOUNQTY
			 , WA.ASNTDTE
			 , WA.ASNSDTE
			 , SS.SALEQTY
			 , A.ROINQTY
			 , A.SALLBYN
			 , case when A.SKUSTAT = 'OUT' then 'Y' else 'N' end as SKUSTAT
		  from (
		  		/* 발주 대상 */
				select OC.COPZZKY, OC.COMPKEY, OC.DCTCTYP, OC.DOCCATE, OC.DOCTYPE, OC.SKUMKEY, MS.SKUDESC, MS.SKUSKEY
					 , MS.VENDKEY , MP.PTNAMLC as VENDNAM , MS.VNDFDAY, MS.MINIQTY, MS.SPROPRC
				     , date_format(date_add(now(), interval + MS.VNDFDAY day),"%Y-%m-%d") as RCVDATE 
					 , sum(OC.SOITQTY) as SOITQTY
					 , sum(OC.RGITQTY) as RGITQTY
					 , OC.CUSTKEY , OC.OWNERKY , OC.RCVWHKY , MS.ROINQTY, OC.SALLBYN
					 , MS.SKUSTAT
				  from OCOPZZ OC
				 inner join MSKUWC MS on OC.COMPKEY = MS.COMPKEY and OC.SKUMKEY = MS.SKUMKEY and OC.OWNERKY = MS.OWNERKY and OC.RCVWHKY = MS.WAREKEY
				 inner join MPTNMA MP on OC.COMPKEY = MP.COMPKEY and MS.VENDKEY = MP.PTNRKEY and MP.PTNRTYP = 'VENDER' and MP.PTDELYN = 'N' 
				 where 1=1 
				   and OC.COMPKEY = #{compkey}
				   and OC.COPZZKY = #{copzzky}
				 group by OC.COPZZKY, OC.COMPKEY, OC.DCTCTYP, OC.DOCCATE, OC.DOCTYPE, OC.SKUMKEY, OC.SKUDESC, MS.SKUSKEY
				        , MS.VENDKEY, MP.PTNAMLC, MS.VNDFDAY, OC.CUSTKEY, OC.CUSTKEY, OC.OWNERKY, MS.WAREKEY, OC.SALLBYN, MS.SKUSTAT
			   ) A  
          left join (
			    /* WMS 가용재고 */											
			    select COMPKEY, WAREKEY, OWNERKY, SKUMKEY, sum((STOTQTY - SBLOQTY) ) as ABALQTY											
			      from WSTKKY w											
			     where COMPKEY = #{compkey}											
			       and WAREKEY != 'WHOLESALE' /* 매장창고 제외  */											
			       and AREAKEY = 'STG' /* 재고 영역 고정 */  											
			       and STOTQTY - SBLOQTY > 0											
			       and SALLQTY = 0											
			       and SINBQTY = 0											
			       and SOUBQTY = 0											
			      group by COMPKEY, WAREKEY, OWNERKY, SKUMKEY
			   ) WS on WS.COMPKEY = A.COMPKEY and WS.WAREKEY = A.RCVWHKY and WS.OWNERKY = A.OWNERKY and WS.SKUMKEY = A.SKUMKEY 
          left join (
          		/* 샘플 미회수 */
			    select OC.COMPKEY, OC.MNGWHKY, OC.OWNERKY, OC.SKUMKEY 
			         , max(OC.SOITQTY) - sum(ifnull(OT.TAKSQTY ,0)+ ifnull(OT.TAKBQTY,0) ) as SQTY230 /* 미회수 샘플 */
				  from OCOSAL OC
				  left join OCOTAK OT on OT.COMPKEY = OC.COMPKEY and OT.COOUTKY = OC.COOUTKY and OT.COOUTIT = OC.COOUTIT 
				 where 1=1 
				   and OC.COMPKEY = #{compkey}
				   and OC.DOCCATE = '200'
				   and OC.DOCTYPE = '230'
				   and OC.CUSTKEY = #{custkey}
				   and OC.SOITQTY - (ifnull(OT.TAKSQTY ,0)+ ifnull(OT.TAKBQTY,0) ) > 0
		         group by OC.COMPKEY, OC.COMPKEY, OC.MNGWHKY, OC.OWNERKY, OC.SKUMKEY
               ) TK on TK.COMPKEY = A.COMPKEY and TK.MNGWHKY = A.RCVWHKY and TK.OWNERKY = A.OWNERKY and TK.SKUMKEY = A.SKUMKEY
          left join (               
                /* 미송 */
			    select OC.COMPKEY, OC.MNGWHKY, OC.OWNERKY, OC.SKUMKEY, sum(OC.SOITQTY-OC.RGITQTY) as SQTY250 
				  from OCOSAL OC 
				 where 1=1 
				   and OC.COMPKEY = #{compkey}
				   and OC.DOCCATE = '200'
				   and OC.DOCTYPE = '250'
		 		   and OC.CUSTKEY = #{custkey}
		 		   and OC.SOITQTY-OC.RGITQTY > 0
				 group by OC.COMPKEY, OC.COMPKEY, OC.MNGWHKY, OC.OWNERKY, OC.SKUMKEY
               ) S5 on S5.COMPKEY = A.COMPKEY and S5.MNGWHKY = A.RCVWHKY and S5.OWNERKY = A.OWNERKY and S5.SKUMKEY = A.SKUMKEY
          left join (
		        /* wms 당일미출(영업일기준)수량 */	
		        select w.COMPKEY, w.WAREKEY, w.OWNERKY, w.SKUMKEY
		             , sum(w.SHCUQTY - w.SHALQTY ) as unflqty /* 미출수량 */
		         from WSHPIT w 		
		         left join OCOSAL o on o.COMPKEY = w.COMPKEY and o.COOUTKY = w.REFSODC and o.COOUTIT = w.REFSOIT 
		        where w.COMPKEY = #{compkey}
		          and w.WAREKEY != 'WHOLESALE' /* 매장창고 제외  */
		          and w.SHCUQTY - w.SHALQTY > 0	 
      <![CDATA[   and o.POSTDAT = ( select CASE WHEN DATE_FORMAT(NOW(), '%H%I') <= POSTSTM  THEN DATE_FORMAT(NOW(), '%Y-%M-%D')
								       	   ELSE DATE_FORMAT( DATE_ADD(NOW(), INTERVAL +1 DAY) , '%Y-%M-%D' )     	 
										   END
									  from MCUSMA M
									 where COMPKEY = #{compkey}
									   and CUSTTYP = 'WHOLESALE'
									   and CUSTKEY = 'ANNE' ) ]]>
		        group by w.COMPKEY, w.WAREKEY, w.OWNERKY, w.SKUMKEY
               ) WU on WU.COMPKEY = A.COMPKEY and WU.WAREKEY = A.RCVWHKY and WU.OWNERKY = A.OWNERKY and WU.SKUMKEY = A.SKUMKEY
		  left outer join (
		  		/* 입고예정 수량  : 오늘, 총  */
		  		select COMPKEY, WAREKEY, OWNERKY, SKUMKEY
		  			 , sum(case when ASNDATE  = to_char(NOW() ,'YYYYMMDD') then ASNDQTY - RCHSQTY else 0 end) as ASNTDTE /* 오늘 입고예정 수량 */
			 	     , sum(ASNDQTY - RCHSQTY) as ASNSDTE /* 총 입고예정 수량 */
		  		  from WASNIF
		  		 where 1=1
		  		   and COMPKEY = #{compkey}
		  		   and ASNSTAT in ('NEW', 'ING' )
		  		   and DOCTYPE in ('420','430')
		  		 group by COMPKEY, WAREKEY, OWNERKY, SKUMKEY
		  	 ) WA
		    on WA.COMPKEY = A.COMPKEY and WA.WAREKEY = A.RCVWHKY and WA.OWNERKY = A.OWNERKY and WA.SKUMKEY = A.SKUMKEY
		  left outer join (
				/* 최근 1년 판매수량  */
			    select OC.COMPKEY, OC.MNGWHKY, OC.OWNERKY, OC.SKUMKEY, sum(OC.SOITQTY) as SALEQTY
				  from OCOSAL OC 
				 where 1=1 
				   and OC.COMPKEY = #{compkey}
				   and OC.DOCCATE = '200'
				   and OC.DOCTYPE in ('210','250','280')
		 		   and OC.CUSTKEY = #{custkey}
		 		   and POSTDAT >=  ADDDATE( now(), INTERVAL -1 year)
		         group by OC.COMPKEY, OC.MNGWHKY, OC.OWNERKY, OC.SKUMKEY
		  	 ) SS on SS.COMPKEY = A.COMPKEY and SS.MNGWHKY = A.RCVWHKY and SS.OWNERKY = A.OWNERKY and SS.SKUMKEY = A.SKUMKEY
		 where 1=1 
		   and A.COPZZKY = #{copzzky}
		 order by A.SKUMKEY
    </select>
    
    omp3 : 임시 저장 테이블 item 에 해당하는 차트 데이터 조회
    <select id="selectItemChtData" parameterType="map" resultType="java.util.HashMap">
		select Json_Arrayagg(date_format(A.STDDATE, '%m-%d') ORDER BY A.STDDATE) as XAXISDT
     		 , Json_Arrayagg(ifnull(B.SOITQTY,0) ORDER BY A.STDDATE) as SERIES1
     		 , Json_Arrayagg(ifnull(B.ORDRCNT,0) ORDER BY A.STDDATE) as SERIES2
  		  from (
        		SELECT STDDATE 
                  from MLSCAL
                 where 1=1
                   and COMPKEY = #{compkey}
          		   and STDDATE BETWEEN date_format(DATE_ADD(NOW(), INTERVAL-60 DAY),'%Y%m%d') AND date_format(NOW(),'%Y%m%d')
    		   ) A left join (
        			select POSTDAT, sum(SOITQTY) as SOITQTY, count(1) as ORDRCNT
          			  from OCOSAL
        		 	 where 1=1 
        		   	   and COMPKEY = #{compkey} 
        		   	   and CUSTKEY = #{custkey}
        		   	   and SKUMKEY = #{skumkey} 
        		   	   and DOCCATE = '200'
        		   	   and DOCTYPE in ('210','250','280')
        		   <![CDATA[ and SALSTAT <> 'ORDER' ]]>
        		   	   and POSTDAT BETWEEN date_format(DATE_ADD(NOW(), INTERVAL-60 DAY),'%Y%m%d') AND date_format(NOW(),'%Y%m%d')
         			 group by POSTDAT
			   ) B on A.STDDATE = B.POSTDAT
		   where 1=1
    </select>
    
